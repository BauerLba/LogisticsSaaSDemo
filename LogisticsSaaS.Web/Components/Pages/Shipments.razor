@page "/shipments"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@using LogisticsSaaS.Core.Domain.Enums
@inject ShipmentService ShipmentService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Shipments | LogiFlow</PageTitle>

<div class="mb-4">
    <div class="page-header">
        <div class="page-header-content">
            <h1>Shipments</h1>
            <p>Manage and track your global logistics operations</p>
        </div>
        <div style="display: flex; gap: 0.75rem;">
            <button class="btn-secondary" @onclick="ExportCSV" title="Export shipments to CSV">
                <i class="fas fa-download"></i> Export CSV
            </button>
            <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/shipments/new")'>
                <i class="fas fa-plus"></i> New Shipment
            </button>
        </div>
    </div>

    <!-- Advanced Filters Card -->
    <div class="card mb-4">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h3 style="margin: 0;">Filters</h3>
            <button @onclick="ResetFilters" style="background: transparent; border: none; color: var(--text-tertiary); cursor: pointer; text-decoration: underline; font-size: 0.875rem;">
                Reset All
            </button>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 1rem; align-items: end;">
            <!-- Search -->
            <div>
                <label for="search-shipment" style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 0.5rem;">
                    Search
                    @if (!string.IsNullOrWhiteSpace(searchTerm) && shipments != null)
                    {
                        <span style="color: var(--text-tertiary);">(@filteredShipments?.Count())</span>
                    }
                </label>
                <input id="search-shipment"
                       type="text"
                       placeholder="Tracking #, Sender, Receiver..."
                       @bind="searchTerm"
                       @bind:event="oninput" />
            </div>

            <!-- Date From -->
            <div>
                <label for="filter-date-from" style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 0.5rem;">From Date</label>
                <input id="filter-date-from"
                       type="date"
                       @bind="filterDateFrom" />
            </div>

            <!-- Date To -->
            <div>
                <label for="filter-date-to" style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 0.5rem;">To Date</label>
                <input id="filter-date-to"
                       type="date"
                       @bind="filterDateTo" />
            </div>

            <!-- Status Multi-Select -->
            <div>
                <label for="filter-status" style="display: block; font-size: 0.875rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 0.5rem;">Status</label>
                <select id="filter-status"
                        @bind="filterStatus"
                        multiple>
                    @foreach (var status in Enum.GetValues<ShipmentStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- Bulk Actions Bar -->
    @if (selectedShipments.Any())
    {
        <div style="background: var(--primary-light); border: 1px solid var(--primary); border-radius: 0.5rem; padding: 1rem; margin-bottom: 1rem; display: flex; justify-content: space-between; align-items: center;">
            <span style="color: var(--text-primary); font-weight: 500;">@selectedShipments.Count selected</span>
            <div style="display: flex; gap: 0.75rem;">
                <select @bind="bulkStatusUpdate" style="padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 0.375rem;">
                    <option value="">Select new status...</option>
                    @foreach (var status in Enum.GetValues<ShipmentStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <button @onclick="ApplyBulkUpdate" class="btn-primary" style="padding: 0.5rem 1rem;">Update Status</button>
                <button @onclick="ClearSelection" class="btn-secondary" style="padding: 0.5rem 1rem;">Clear</button>
            </div>
        </div>
    }

    <!-- Shipments Table -->
    <div class="card">
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: 600; background: var(--bg-secondary);">
                        <th style="padding: 1rem; text-align: center; width: 40px;">
                            <input type="checkbox" @onchange="SelectAll" style="cursor: pointer;" />
                        </th>
                        <th style="padding: 1rem; text-align: left;">TRACKING #</th>
                        <th style="padding: 1rem; text-align: left;">SENDER / RECEIVER</th>
                        <th style="padding: 1rem; text-align: left;">ORIGIN</th>
                        <th style="padding: 1rem; text-align: left;">DESTINATION</th>
                        <th style="padding: 1rem; text-align: left;">STATUS</th>
                        <th style="padding: 1rem; text-align: left;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filteredShipments != null)
                    {
                        @if (!filteredShipments.Any())
                        {
                            <tr>
                                <td colspan="6" style="padding: 2rem; text-align: center; color: var(--text-tertiary);">
                                    <i class="fas fa-inbox" style="font-size: 2rem; opacity: 0.5; margin-bottom: 0.5rem;"></i>
                                    <p style="margin: 0;">No shipments found.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var shipment in filteredShipments)
                            {
                                <tr class="shipment-row" style="border-bottom: 1px solid var(--border-color);">
                                    <td style="padding: 1rem; text-align: center;" @onclick:stopPropagation="true">
                                        <input type="checkbox"
                                               @onchange="@((ChangeEventArgs e) => ToggleShipment(shipment.TrackingNumber, (bool)e.Value!))"
                                               style="cursor: pointer;" />
                                    </td>
                                    <td style="padding: 1rem; font-weight: 600; font-family: 'Monaco', 'Courier New', monospace; color: var(--primary); cursor: pointer;"
                                        @onclick='() => Navigation.NavigateTo($"/shipment/{shipment.TrackingNumber}")'>
                                        @shipment.TrackingNumber
                                    </td>
                                    <td style="padding: 1rem; cursor: pointer;"
                                        @onclick='() => Navigation.NavigateTo($"/shipment/{shipment.TrackingNumber}")'>
                                        <div style="font-weight: 500; color: var(--text-primary);">@shipment.SenderName</div>
                                        <div style="font-size: 0.75rem; color: var(--text-tertiary); margin-top: 0.25rem;">to @shipment.ReceiverName</div>
                                    </td>
                                    <td style="padding: 1rem; color: var(--text-secondary); cursor: pointer;"
                                        @onclick='() => Navigation.NavigateTo($"/shipment/{shipment.TrackingNumber}")'>@shipment.Origin</td>
                                    <td style="padding: 1rem; color: var(--text-secondary); cursor: pointer;"
                                        @onclick='() => Navigation.NavigateTo($"/shipment/{shipment.TrackingNumber}")'>@shipment.Destination</td>
                                    <td style="padding: 1rem; cursor: pointer;"
                                        @onclick='() => Navigation.NavigateTo($"/shipment/{shipment.TrackingNumber}")'>
                                        <span class="status-badge status-@shipment.Status.ToString().ToLower()">
                                            @shipment.Status
                                        </span>
                                    </td>
                                    <td style="padding: 1rem;">
                                        <a href="/shipment/@shipment.TrackingNumber"
                                           style="color: var(--primary); text-decoration: none; font-size: 0.875rem; font-weight: 500;">
                                            View Details →
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    }
                    else
                    {
                        @for (int i = 0; i < 5; i++)
                        {
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td style="padding: 1rem;">
                                    <div class="skeleton skeleton-text" style="width: 120px;"></div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div class="skeleton skeleton-text" style="width: 150px;"></div>
                                    <div class="skeleton skeleton-text" style="width: 120px; margin-top: 0.5rem;"></div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div class="skeleton skeleton-text" style="width: 100px;"></div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div class="skeleton skeleton-text" style="width: 100px;"></div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div class="skeleton skeleton-badge" style="width: 70px;"></div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div class="skeleton skeleton-text" style="width: 80px;"></div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (shipments != null && totalPages > 1)
        {
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color);">
                <div style="color: var(--text-tertiary); font-size: 0.875rem;">
                    Showing @((currentPage - 1) * pageSize + 1) to @Math.Min(currentPage * pageSize, totalCount) of @totalCount
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button @onclick="() => GoToPage(currentPage - 1)"
                            disabled="@(currentPage == 1)"
                            style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: var(--bg-secondary); border-radius: 0.375rem; cursor: pointer; color: var(--text-primary); transition: var(--transition-fast);"
                            class="@(currentPage == 1 ? "opacity-50" : "")">
                        <i class="fas fa-chevron-left"></i> Previous
                    </button>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNum = i;
                        <button @onclick="() => GoToPage(pageNum)"
                                style="min-width: 2.5rem; padding: 0.5rem 0.75rem; border: 1px solid @(currentPage == pageNum ? "var(--primary)" : "var(--border-color)"); background: @(currentPage == pageNum ? "var(--primary-light)" : "var(--bg-secondary)"); border-radius: 0.375rem; cursor: pointer; color: @(currentPage == pageNum ? "var(--primary)" : "var(--text-primary)"); font-weight: @(currentPage == pageNum ? "600" : "500"); transition: var(--transition-fast);">
                            @pageNum
                        </button>
                    }

                    <button @onclick="() => GoToPage(currentPage + 1)"
                            disabled="@(currentPage == totalPages)"
                            style="padding: 0.5rem 1rem; border: 1px solid var(--border-color); background: var(--bg-secondary); border-radius: 0.375rem; cursor: pointer; color: var(--text-primary); transition: var(--transition-fast);"
                            class="@(currentPage == totalPages ? "opacity-50" : "")">
                        Next <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IEnumerable<Shipment>? shipments;
    private string searchTerm = "";
    private string filterStatus = "";
    private DateTime? filterDateFrom;
    private DateTime? filterDateTo;
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int totalPages = 1;
    private HashSet<string> selectedShipments = new();
    private string bulkStatusUpdate = "";

    private IEnumerable<Shipment>? filteredShipments
    {
        get
        {
            if (shipments == null) return null;

            var filtered = shipments
                .Where(s => (string.IsNullOrWhiteSpace(searchTerm) ||
                             s.TrackingNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                             s.SenderName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                             s.ReceiverName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
                            (string.IsNullOrWhiteSpace(filterStatus) || s.Status.ToString() == filterStatus) &&
                            (!filterDateFrom.HasValue || s.CreatedAt.Date >= filterDateFrom.Value.Date) &&
                            (!filterDateTo.HasValue || s.CreatedAt.Date <= filterDateTo.Value.Date));

            totalCount = filtered.Count();
            totalPages = (int)Math.Ceiling((double)totalCount / pageSize);

            return filtered
                .OrderByDescending(s => s.CreatedAt)
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        shipments = await ShipmentService.GetActiveShipmentsAsync();
    }

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
        }
    }

    private void ResetFilters()
    {
        searchTerm = "";
        filterStatus = "";
        filterDateFrom = null;
        filterDateTo = null;
        currentPage = 1;
    }

    private void ToggleShipment(string trackingNumber, bool isSelected)
    {
        if (isSelected)
            selectedShipments.Add(trackingNumber);
        else
            selectedShipments.Remove(trackingNumber);
    }

    private void SelectAll(ChangeEventArgs e)
    {
        if ((bool)e.Value!)
        {
            selectedShipments.Clear();
            foreach (var shipment in filteredShipments ?? Enumerable.Empty<Shipment>())
            {
                selectedShipments.Add(shipment.TrackingNumber);
            }
        }
        else
        {
            selectedShipments.Clear();
        }
    }

    private void ClearSelection()
    {
        selectedShipments.Clear();
    }

    private async Task ApplyBulkUpdate()
    {
        if (string.IsNullOrEmpty(bulkStatusUpdate) || !selectedShipments.Any())
            return;

        if (Enum.TryParse<ShipmentStatus>(bulkStatusUpdate, out var newStatus))
        {
            foreach (var tracking in selectedShipments)
            {
                var shipment = shipments?.FirstOrDefault(s => s.TrackingNumber == tracking);
                if (shipment != null)
                {
                    await ShipmentService.UpdateStatusAsync(shipment.Id, newStatus);
                }
            }

            selectedShipments.Clear();
            bulkStatusUpdate = "";
            shipments = await ShipmentService.GetActiveShipmentsAsync();
        }
    }

    private async Task ExportCSV()
    {
        try
        {
            var csv = await ShipmentService.ExportToCSVAsync();
            var filename = $"shipments-{DateTime.Now:yyyy-MM-dd-HHmmss}.csv";
            await JS.InvokeVoidAsync("downloadFile", filename, csv);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Export failed: {ex.Message}");
        }
    }
}
