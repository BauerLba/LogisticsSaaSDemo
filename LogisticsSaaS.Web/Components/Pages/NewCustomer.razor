@page "/customers/new"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@inject CustomerService CustomerService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="dashboard-container" style="max-width: 800px; margin: 0 auto;">
    <div style="margin-bottom: 2.5rem;">
        <button @onclick="GoBack" disabled="@isSubmitting"
                style="background: transparent; border: none; color: var(--text-muted); cursor: pointer; margin-bottom: 1rem; opacity: @(isSubmitting ? 0.5 : 1);">
            <i class="fas fa-arrow-left"></i> Back to Customers
        </button>
        <h1 style="margin: 0; font-size: 2.5rem;">New Customer</h1>
        <p style="color: var(--text-muted);">Add a new partner or client to your network</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem; color: #f87171; font-size: 0.875rem;">
            <i class="fas fa-circle-exclamation" style="margin-right: 0.5rem;"></i>
            @errorMessage
        </div>
    }

    <div class="glass-card">
        <EditForm Model="@newCustomer" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div>
                    <label class="form-label">Company / Name *</label>
                    <InputText @bind-Value="newCustomer.Name"  placeholder="e.g. Acme Corp" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newCustomer.Name)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
                <div>
                    <label class="form-label">Email *</label>
                    <InputText @bind-Value="newCustomer.Email"  placeholder="e.g. ops@acme.com" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newCustomer.Email)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label class="form-label">Location</label>
                <InputText @bind-Value="newCustomer.Location"  placeholder="e.g. Berlin, Germany" disabled="@isSubmitting" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
                <div>
                    <label class="form-label">Active Shipments</label>
                    <InputNumber @bind-Value="newCustomer.ActiveShipments"  disabled="@isSubmitting" />
                </div>
                <div>
                    <label class="form-label">Total Spent ($)</label>
                    <InputNumber @bind-Value="newCustomer.TotalSpent"  disabled="@isSubmitting" />
                </div>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                <button type="button" @onclick="GoBack" class="btn-secondary"
                        disabled="@isSubmitting"
                        style="padding: 0.8rem 2rem; opacity: @(isSubmitting ? 0.5 : 1); cursor: @(isSubmitting ? "not-allowed" : "pointer");">
                    Cancel
                </button>
                <button type="submit" class="btn-primary" disabled="@isSubmitting"
                        style="padding: 0.8rem 2rem; display: flex; align-items: center; gap: 0.5rem;">
                    @if (isSubmitting)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <i class="fas fa-plus"></i>
                        <span>Create Customer</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
</div>

<style>
    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-muted);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: white;
        border-radius: 12px;
        cursor: pointer;
        transition: var(--transition);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
    }
</style>

@code {
    private Customer newCustomer = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;
            await CustomerService.CreateCustomerAsync(newCustomer);
            Navigation.NavigateTo("/customers");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create customer: {ex.Message}";
            isSubmitting = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/customers");
}
