@page "/shipments/new"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@using LogisticsSaaS.Core.Domain.Enums
@inject ShipmentService ShipmentService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="dashboard-container" style="max-width: 800px; margin: 0 auto;">
    <div style="margin-bottom: 2.5rem;">
        <button @onclick="GoBack" disabled="@isSubmitting"
                style="background: transparent; border: none; color: var(--text-muted); cursor: pointer; margin-bottom: 1rem; opacity: @(isSubmitting ? 0.5 : 1);">
            <i class="fas fa-arrow-left"></i> Back to Shipments
        </button>
        <h1 style="margin: 0; font-size: 2.5rem;">New Shipment</h1>
        <p style="color: var(--text-muted);">Create a new logistics entry for tracking</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem; color: #f87171; font-size: 0.875rem;">
            <i class="fas fa-circle-exclamation" style="margin-right: 0.5rem;"></i>
            @errorMessage
        </div>
    }

    <div class="glass-card">
        <EditForm Model="@newShipment" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div>
                    <label class="form-label">Sender Name *</label>
                    <InputText @bind-Value="newShipment.SenderName" class="tracking-input"
                               placeholder="e.g. Acme Corp" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newShipment.SenderName)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
                <div>
                    <label class="form-label">Receiver Name *</label>
                    <InputText @bind-Value="newShipment.ReceiverName" class="tracking-input"
                               placeholder="e.g. John Doe" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newShipment.ReceiverName)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div>
                    <label class="form-label">Origin Location *</label>
                    <InputText @bind-Value="newShipment.Origin" class="tracking-input"
                               placeholder="e.g. New York, US" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newShipment.Origin)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
                <div>
                    <label class="form-label">Destination Location *</label>
                    <InputText @bind-Value="newShipment.Destination" class="tracking-input"
                               placeholder="e.g. Tokyo, JP" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newShipment.Destination)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
                <div>
                    <label class="form-label">Weight (kg) *</label>
                    <InputNumber @bind-Value="newShipment.Weight" class="tracking-input" disabled="@isSubmitting" />
                    <ValidationMessage For="@(() => newShipment.Weight)" class="form-error-message">
                        <i class="fas fa-exclamation-circle"></i>
                    </ValidationMessage>
                </div>
                <div>
                    <label class="form-label">Initial Status</label>
                    <InputSelect @bind-Value="newShipment.Status" class="tracking-input" disabled="@isSubmitting">
                        @foreach (var status in Enum.GetValues<ShipmentStatus>())
                        {
                            <option value="@status">@status</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div style="display: flex; justify-content: flex-end; gap: 1rem;">
                <button type="button" @onclick="GoBack" class="btn-secondary"
                        disabled="@isSubmitting"
                        style="padding: 0.8rem 2rem; opacity: @(isSubmitting ? 0.5 : 1); cursor: @(isSubmitting ? "not-allowed" : "pointer");">
                    Cancel
                </button>
                <button type="submit" class="btn-primary" disabled="@isSubmitting"
                        style="padding: 0.8rem 2rem; display: flex; align-items: center; gap: 0.5rem;">
                    @if (isSubmitting)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <span>Create Shipment</span>
                    }
                </button>
            </div>
        </EditForm>
    </div>
</div>

<style>
    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-muted);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--glass-border);
        color: white;
        border-radius: 12px;
        cursor: pointer;
        transition: var(--transition);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
    }
</style>

@code {
    private Shipment newShipment = new();
    private bool isSubmitting = false;
    private string? errorMessage;

    private async Task HandleSubmit()
    {
        try
        {
            isSubmitting = true;
            errorMessage = null;
            await ShipmentService.CreateShipmentAsync(newShipment);
            Navigation.NavigateTo("/shipments");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create shipment: {ex.Message}";
            isSubmitting = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/shipments");
}
