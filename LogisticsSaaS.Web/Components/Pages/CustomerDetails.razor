@page "/customer/{Id}"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@inject CustomerService CustomerService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Customer @Id | LogiFlow</PageTitle>

<div class="mb-4">
    <button @onclick="GoBack"
            style="background: transparent; border: none; color: var(--primary); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0; font-weight: 500;">
        <i class="fas fa-arrow-left"></i> Back to Customers
    </button>
</div>

@if (customer == null)
{
    <div class="card text-center" style="padding: 4rem;">
        <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary); margin-bottom: 1rem;"></i>
        <h2 class="mt-4">Loading Customer...</h2>
    </div>
}
else
{
    <div style="display: grid; grid-template-columns: 300px 1fr; gap: 2rem;">
        <!-- Sidebar -->
        <div>
            <div class="card text-center">
                <div class="customer-icon-lg" style="background: @customer.Color; margin: 0 auto 1.5rem;">
                    <i class="fas @customer.Icon"></i>
                </div>
                <h2 style="margin: 0 0 0.5rem;">@customer.Name</h2>
                <span class="text-muted text-sm" style="font-family: 'Monaco', 'Courier New', monospace; display: block;">@customer.Id</span>
            </div>
        </div>

        <!-- Main Content -->
        <div>
            <!-- Contact Card -->
            <div class="card mb-4">
                <h2 class="mt-0">Contact Information</h2>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 0.5rem; background: var(--primary-light); display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0;">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div>
                            <div class="text-muted text-sm font-600 uppercase">Email</div>
                            <div class="font-500" style="color: var(--text-primary);">@customer.Email</div>
                        </div>
                    </div>

                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 0.5rem; background: rgba(16,185,129,0.1); display: flex; align-items: center; justify-content: center; color: var(--status-success); flex-shrink: 0;">
                            <i class="fas fa-location-dot"></i>
                        </div>
                        <div>
                            <div class="text-muted text-sm font-600 uppercase">Location</div>
                            <div class="font-500" style="color: var(--text-primary);">@customer.Location</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <div class="card text-center">
                    <div style="font-size: 2.5rem; font-weight: 700; color: var(--primary); margin-bottom: 0.75rem;">
                        @customer.ActiveShipments
                    </div>
                    <div class="text-muted text-sm font-600 uppercase">
                        Active Shipments
                    </div>
                </div>

                <div class="card text-center">
                    <div style="font-size: 2.5rem; font-weight: 700; color: var(--status-success); margin-bottom: 0.75rem;">
                        @customer.TotalSpent.ToString("C0")
                    </div>
                    <div class="text-muted text-sm font-600 uppercase">
                        Total Spent
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .customer-icon-lg {
        width: 100px;
        height: 100px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2.5rem;
        flex-shrink: 0;
    }
</style>

@code {
    [Parameter] public string? Id { get; set; }
    private Customer? customer;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Id))
            customer = await CustomerService.GetCustomerByIdAsync(Id);
    }

    private void GoBack() => Navigation.NavigateTo("/customers");
}
