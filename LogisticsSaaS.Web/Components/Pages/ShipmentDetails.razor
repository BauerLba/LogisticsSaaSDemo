@page "/shipment/{TrackingNumber}"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@using LogisticsSaaS.Core.Domain.Enums
@inject ShipmentService ShipmentService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Shipment @TrackingNumber | LogiFlow</PageTitle>

<div class="mb-4">
    <button @onclick="GoBack"
            style="background: transparent; border: none; color: var(--primary); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0; font-weight: 500;">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
    </button>
</div>

@if (shipment == null)
{
    <div class="card text-center" style="padding: 4rem;">
        <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary); margin-bottom: 1rem;"></i>
        <h2 class="mt-4">Finding Shipment...</h2>
    </div>
}
else
{
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-bottom: 2rem;">
        <!-- Main Content -->
        <div>
            <!-- Header Card -->
            <div class="card mb-4">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem;">
                    <div>
                        <h1 style="margin: 0 0 0.5rem 0;">Shipment Details</h1>
                        <p style="color: var(--primary); font-family: 'Monaco', 'Courier New', monospace; font-size: 1.1rem; margin: 0;">
                            @shipment.TrackingNumber
                        </p>
                    </div>
                    <span class="status-badge status-@shipment.Status.ToString().ToLower()" style="padding: 0.5rem 1rem; font-size: 0.9rem;">
                        @shipment.Status
                    </span>
                </div>

                <!-- Progress Tracker -->
                <div style="margin: 2.5rem 0;">
                    <div style="display: flex; justify-content: space-between; position: relative;">
                        <div style="position: absolute; top: 15px; left: 0; right: 0; height: 2px; background: var(--border-color);"></div>
                        @{
                            var statuses = new[] { ShipmentStatus.Pending, ShipmentStatus.Processing, ShipmentStatus.InTransit, ShipmentStatus.Delivered };
                        }
                        @foreach (var status in statuses)
                        {
                            var isActive = (int)shipment.Status >= (int)status;
                            <div style="z-index: 2; text-align: center; position: relative;">
                                <div style="width: 36px; height: 36px; border-radius: 50%; background: @(isActive ? "var(--primary)" : "var(--bg-secondary)"); border: 3px solid @(isActive ? "var(--primary)" : "var(--border-color)"); margin: 0 auto; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                                    @if ((int)shipment.Status > (int)status)
                                    {
                                        <i class="fas fa-check" style="font-size: 0.8rem;"></i>
                                    }
                                    else if (shipment.Status == status)
                                    {
                                        <div style="width: 10px; height: 10px; border-radius: 50%; background: white; animation: pulse 2s infinite;"></div>
                                    }
                                </div>
                                <div style="margin-top: 0.75rem; font-size: 0.75rem; color: @(isActive ? "var(--text-primary)" : "var(--text-tertiary)"); font-weight: @(shipment.Status == status ? "600" : "400");">
                                    @status
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- History Card -->
            <div class="card">
                <h2 class="mt-0 mb-3">Shipment Timeline</h2>
                <div>
                    @{
                        var history = GetHistory(shipment);
                    }
                    @foreach (var (item, index) in history.Select((x, i) => (x, i)))
                    {
                        <div style="display: flex; gap: 1.5rem; @(index != history.Count - 1 ? "padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-color);" : "")">
                            <div style="position: relative; width: 1.5rem; flex-shrink: 0;">
                                <div style="position: absolute; top: 2px; left: 50%; transform: translateX(-50%); width: 12px; height: 12px; border-radius: 50%; background: @(item.IsMain ? "var(--primary)" : "var(--border-color)");"></div>
                                @if (index != history.Count - 1)
                                {
                                    <div style="position: absolute; top: 20px; left: 50%; transform: translateX(-50%); width: 2px; height: 40px; background: @(item.IsMain ? "var(--primary)" : "var(--border-color)");"></div>
                                }
                            </div>
                            <div style="flex: 1; padding-top: 0.25rem;">
                                <div class="font-600" style="color: var(--text-primary); margin-bottom: 0.25rem;">@item.Status</div>
                                <div style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 0.25rem;">@item.Description</div>
                                <div class="text-muted text-sm">@item.Time</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div>
            <!-- Info Card -->
            <div class="card mb-4">
                <h3 class="pt-0 mb-3">Shipment Info</h3>

                <div class="mb-3 pb-3 border-bottom">
                    <div class="text-muted text-sm font-600 uppercase mb-2">From</div>
                    <div style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.25rem;">@shipment.SenderName</div>
                    <div class="text-muted text-sm">@shipment.Origin</div>
                </div>

                <div class="mb-3 pb-3 border-bottom">
                    <div class="text-muted text-sm font-600 uppercase mb-2">To</div>
                    <div style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.25rem;">@shipment.ReceiverName</div>
                    <div class="text-muted text-sm">@shipment.Destination</div>
                </div>

                <div>
                    <div class="text-muted text-sm font-600 uppercase mb-2">Weight</div>
                    <div style="font-weight: 600; color: var(--text-primary);">@shipment.Weight kg</div>
                </div>
            </div>

            <!-- CTA Card -->
            <div class="card" style="background: var(--primary-light); border-color: var(--primary-light);">
                <h3 style="margin-top: 0; color: var(--primary);">Need Assistance?</h3>
                <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0.5rem 0 1rem 0;">
                    Contact our support team for help with this shipment.
                </p>
                <button class="btn-primary" style="width: 100%;" @onclick="() => showSupportModal = true">
                    <i class="fas fa-headset"></i> Contact Support
                </button>
            </div>
        </div>
    </div>
}

<!-- Support Modal -->
@if (showSupportModal)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;"
         @onclick="() => showSupportModal = false">
        <div class="card" style="max-width: 480px; width: 90%; position: relative;"
             @onclick:stopPropagation="true">
            <button @onclick="() => showSupportModal = false"
                    style="position: absolute; top: 1.5rem; right: 1.5rem; background: transparent; border: none; color: var(--text-tertiary); cursor: pointer; font-size: 1.2rem; padding: 0.5rem; width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-xmark"></i>
            </button>

            <div class="text-center mb-4">
                <div style="width: 60px; height: 60px; border-radius: 0.5rem; background: var(--primary-light); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;">
                    <i class="fas fa-headset" style="font-size: 1.5rem; color: var(--primary);"></i>
                </div>
                <h2 style="margin: 0 0 0.5rem 0;">Support</h2>
                <p class="text-muted text-sm" style="margin: 0;">Tracking <span style="font-family: 'Monaco', 'Courier New', monospace; color: var(--primary);">@TrackingNumber</span></p>
            </div>

            <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
                <div style="display: flex; align-items: center; gap: 0.75rem; padding: 1rem; background: var(--bg-secondary); border-radius: 0.5rem;">
                    <i class="fas fa-envelope" style="color: var(--primary); width: 1.25rem; text-align: center;"></i>
                    <div style="flex: 1;">
                        <div class="text-muted text-sm font-600 uppercase">Email</div>
                        <div class="font-500" style="color: var(--text-primary);">support@logiflow.com</div>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 0.75rem; padding: 1rem; background: var(--bg-secondary); border-radius: 0.5rem;">
                    <i class="fas fa-phone" style="color: var(--status-success); width: 1.25rem; text-align: center;"></i>
                    <div style="flex: 1;">
                        <div class="text-muted text-sm font-600 uppercase">Phone</div>
                        <div class="font-500" style="color: var(--text-primary);">+49 30 1234 5678</div>
                    </div>
                </div>

                <div style="display: flex; align-items: center; gap: 0.75rem; padding: 1rem; background: var(--bg-secondary); border-radius: 0.5rem;">
                    <i class="fas fa-clock" style="color: var(--status-warning); width: 1.25rem; text-align: center;"></i>
                    <div style="flex: 1;">
                        <div class="text-muted text-sm font-600 uppercase">Hours</div>
                        <div class="font-500" style="color: var(--text-primary);">Mon–Fri, 08:00–18:00 CET</div>
                    </div>
                </div>
            </div>

            <button class="btn-secondary" style="width: 100%; margin: 0;" @onclick="() => showSupportModal = false">Close</button>
        </div>
    </div>
}

<style>
    @@keyframes pulse {
        0% { transform: scale(0.95); }
        50% { transform: scale(1.1); }
        100% { transform: scale(0.95); }
    }
</style>

@code {
    [Parameter] public string? TrackingNumber { get; set; }
    private Shipment? shipment;
    private bool showSupportModal = false;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(TrackingNumber))
        {
            shipment = await ShipmentService.TrackShipmentAsync(TrackingNumber);
        }
    }

    private void GoBack() => Navigation.NavigateTo("/");

    private List<HistoryItem> GetHistory(Shipment s)
    {
        var list = new List<HistoryItem>();
        if (s.Status >= ShipmentStatus.Delivered)
            list.Add(new() { Time = "Today, 04:15 PM", Status = "Delivered", Description = "Package has been successfully delivered.", IsMain = true });
        if (s.Status >= ShipmentStatus.InTransit)
            list.Add(new() { Time = "Today, 10:45 AM", Status = "In Transit", Description = $"Package is moving from {s.Origin} to {s.Destination}.", IsMain = true });
        if (s.Status >= ShipmentStatus.Processing)
            list.Add(new() { Time = "Yesterday, 02:30 PM", Status = "Processing", Description = "Package has been scanned at the distribution center.", IsMain = true });
        list.Add(new() { Time = s.CreatedAt.ToString("MMM dd, hh:mm tt"), Status = "Pending", Description = "Shipment instruction received.", IsMain = true });
        return list;
    }

    private class HistoryItem
    {
        public string Time { get; set; } = "";
        public string Status { get; set; } = "";
        public string Description { get; set; } = "";
        public bool IsMain { get; set; }
    }
}
