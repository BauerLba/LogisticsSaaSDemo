@page "/customers"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@inject CustomerService CustomerService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Customers | LogiFlow</PageTitle>

<div class="mb-4">
    <div class="page-header">
        <div class="page-header-content">
            <h1>Customers</h1>
            <p>Manage your partner network and client relations</p>
        </div>
        <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/customers/new")'>
            <i class="fas fa-plus"></i> Add Customer
        </button>
    </div>

    @if (customers == null)
    {
        <div class="text-center" style="padding: 4rem;">
            <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary); margin-right: 0.75rem;"></i>
        </div>
    }
    else if (!customers.Any())
    {
        <div class="card text-center" style="padding: 3rem;">
            <i class="fas fa-inbox" style="font-size: 2rem; color: var(--text-tertiary); margin-bottom: 1rem;"></i>
            <p class="text-muted">No customers yet. Start by adding your first customer.</p>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            @foreach (var customer in customers)
            {
                <div class="card" style="cursor: pointer; transition: all 150ms; display: flex; flex-direction: column;"
                     @onclick='() => Navigation.NavigateTo($"/customer/{customer.Id}")'
                     onmouseover="this.style.boxShadow='var(--shadow-md)'; this.style.borderColor='var(--primary-light)'"
                     onmouseout="this.style.boxShadow='var(--shadow-sm)'; this.style.borderColor='var(--border-color)'">

                    <!-- Header -->
                    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                        <div class="customer-icon" style="background: @customer.Color;">
                            <i class="fas @customer.Icon"></i>
                        </div>
                        <div>
                            <h3 class="text-xl" style="margin: 0 0 0.25rem 0;">@customer.Name</h3>
                            <span class="text-muted text-sm">ID: @customer.Id</span>
                        </div>
                    </div>

                    <!-- Contact Info -->
                    <div class="mb-3 text-base">
                        <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
                            <i class="fas fa-envelope" style="width: 1rem; text-align: center; color: var(--text-tertiary);"></i>
                            @customer.Email
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);">
                            <i class="fas fa-location-dot" style="width: 1rem; text-align: center; color: var(--text-tertiary);"></i>
                            @customer.Location
                        </div>
                    </div>

                    <!-- Stats -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border-color); margin-top: auto;">
                        <div>
                            <div class="text-muted text-sm font-600 uppercase mb-2">Active Shipments</div>
                            <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-primary);">
                                @customer.ActiveShipments
                            </div>
                        </div>
                        <div>
                            <div class="text-muted text-sm font-600 uppercase mb-2">Total Spent</div>
                            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);">
                                @customer.TotalSpent.ToString("C0")
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .customer-icon {
        width: 48px;
        height: 48px;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
        flex-shrink: 0;
    }
</style>

@code {
    private IEnumerable<Customer>? customers;

    protected override async Task OnInitializedAsync()
    {
        customers = await CustomerService.GetCustomersAsync();
    }
}
