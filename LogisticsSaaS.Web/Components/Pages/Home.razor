@page "/"
@using LogisticsSaaS.Core.Application.Services
@using LogisticsSaaS.Core.Domain.Entities
@using LogisticsSaaS.Core.Domain.Enums
@inject ShipmentService ShipmentService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Dashboard | LogiFlow</PageTitle>

<div class="mb-4">
    <div class="page-header">
        <div class="page-header-content">
            <h1>Logistics Dashboard</h1>
            <p>Welcome back! Here's what's happening with your shipments today.</p>
        </div>
        <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/shipments/new")'>
            <i class="fas fa-plus"></i> New Shipment
        </button>
    </div>

    <!-- Stats Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div class="card">
            <div class="text-muted text-sm font-600 mb-2">Total Shipments</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">
                @shipments?.Count()
            </div>
            <div style="color: var(--status-success); font-size: 0.8rem;">
                <i class="fas fa-arrow-up"></i> 12% from last month
            </div>
        </div>

        <div class="card">
            <div class="text-muted text-sm font-600 mb-2">In Transit</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">
                @shipments?.Count(s => s.Status == ShipmentStatus.InTransit)
            </div>
            <div style="color: var(--accent); font-size: 0.8rem;">Currently moving</div>
        </div>

        <div class="card">
            <div class="text-muted text-sm font-600 mb-2">Pending</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">
                @shipments?.Count(s => s.Status == ShipmentStatus.Pending)
            </div>
            <div style="color: var(--status-warning); font-size: 0.8rem;">Awaiting processing</div>
        </div>

        <div class="card">
            <div class="text-muted text-sm font-600 mb-2">Delivered (Today)</div>
            <div style="font-size: 2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">0</div>
            <div class="text-muted text-sm">Daily goal: 25</div>
        </div>
    </div>

    <!-- Active Shipments Table -->
    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2>Active Shipments</h2>
            <input type="text"
                   placeholder="Search tracking number..."
                   @bind="dashboardSearchTerm"
                   @onkeyup="HandleDashboardSearch"
                   style="width: 300px; padding: 0.5rem 0.75rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-size: 0.875rem; background: var(--bg-secondary); color: var(--text-primary);" />
        </div>

        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
                <thead>
                    <tr style="text-align: left; border-bottom: 2px solid var(--border-color); color: var(--text-secondary); font-weight: 600; background: var(--bg-secondary);">
                        <th style="padding: 1rem;">TRACKING #</th>
                        <th style="padding: 1rem;">SENDER / RECEIVER</th>
                        <th style="padding: 1rem;">ROUTE</th>
                        <th style="padding: 1rem;">WEIGHT</th>
                        <th style="padding: 1rem;">STATUS</th>
                        <th style="padding: 1rem;">EST. DELIVERY</th>
                    </tr>
                </thead>
                <tbody>
                    @if (filteredShipments == null)
                    {
                        <tr>
                            <td colspan="6" style="padding: 2rem; text-align: center; color: var(--text-tertiary);">
                                <i class="fas fa-circle-notch fa-spin" style="margin-right: 0.5rem;"></i> Loading data...
                            </td>
                        </tr>
                    }
                    else if (!filteredShipments.Any())
                    {
                        <tr>
                            <td colspan="6" style="padding: 2rem; text-align: center; color: var(--text-tertiary);">
                                No shipments found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var shipment in filteredShipments)
                        {
                            <tr style="border-bottom: 1px solid var(--border-color); transition: background-color 150ms; cursor: pointer;"
                                @onclick='() => Navigation.NavigateTo($"/shipment/{shipment.TrackingNumber}")'
                                onmouseover="this.style.backgroundColor='var(--bg-secondary)'"
                                onmouseout="this.style.backgroundColor='transparent'">
                                <td style="padding: 1rem; font-family: 'Monaco', 'Courier New', monospace; font-weight: 600; color: var(--primary);">
                                    @shipment.TrackingNumber
                                </td>
                                <td style="padding: 1rem;">
                                    <div style="font-weight: 500; color: var(--text-primary);">@shipment.SenderName</div>
                                    <div style="font-size: 0.75rem; color: var(--text-tertiary); margin-top: 0.25rem;">to @shipment.ReceiverName</div>
                                </td>
                                <td style="padding: 1rem;">
                                    <div style="font-size: 0.875rem; color: var(--text-secondary);">@shipment.Origin</div>
                                    <div style="font-size: 0.7rem; color: var(--text-tertiary); margin: 0.25rem 0;"><i class="fas fa-arrow-down"></i></div>
                                    <div style="font-size: 0.875rem; color: var(--text-secondary);">@shipment.Destination</div>
                                </td>
                                <td style="padding: 1rem; color: var(--text-secondary);">@shipment.Weight kg</td>
                                <td style="padding: 1rem;">
                                    <span class="status-badge status-@shipment.Status.ToString().ToLower()">
                                        @shipment.Status
                                    </span>
                                </td>
                                <td style="padding: 1rem; color: var(--text-tertiary);">
                                    @(shipment.EstimatedDelivery?.ToShortDateString() ?? "TBD")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private IEnumerable<Shipment>? shipments;
    private string dashboardSearchTerm = "";

    private IEnumerable<Shipment>? filteredShipments => shipments?
        .Where(s => string.IsNullOrWhiteSpace(dashboardSearchTerm) || s.TrackingNumber.Contains(dashboardSearchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        shipments = await ShipmentService.GetActiveShipmentsAsync();
    }

    private void HandleDashboardSearch(KeyboardEventArgs e)
    {
    }
}
